# STAGE 3 \u2014 Basic solver (naked + hidden singles)
# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

def candidates(g):
    """Return dict of (r,c) \u2192 set of valid candidates for blank cells."""
    cands = {}
    for r in range(9):
        for c in range(9):
            if g[r][c] == 0:
                used = set(g[r]) | set(g[i][c] for i in range(9))
                br, bc = (r // 3) * 3, (c // 3) * 3
                used |= set(g[i][j] for i in range(br, br + 3) for j in range(bc, bc + 3))
                cands[(r, c)] = set(range(1, 10)) - used
    return cands

def basic_solve(g):
    """Apply naked singles and hidden singles until stuck. Returns solved-so-far grid."""
    g2 = copy.deepcopy(g)
    changed = True
    while changed:
        changed = False
        cands = candidates(g2)

        # Naked singles
        for (r, c), v in cands.items():
            if len(v) == 1:
                g2[r][c] = list(v)[0]
                changed = True
        if changed: continue

        # Hidden singles
        cands = candidates(g2)
        for n in range(1, 10):
            for r in range(9):
                cells = [(r, c) for c in range(9) if n in cands.get((r, c), set())]
                if len(cells) == 1:
                    g2[cells[0][0]][cells[0][1]] = n; changed = True; break
            if changed: break
            for c in range(9):
                cells = [(r, c) for r in range(9) if n in cands.get((r, c), set())]
                if len(cells) == 1:
                    g2[cells[0][0]][cells[0][1]] = n; changed = True; break
            if changed: break
            for br in range(0, 9, 3):
                for bc in range(0, 9, 3):
                    cells = [(r, c) for r in range(br, br + 3) for c in range(bc, bc + 3)
                             if n in cands.get((r, c), set())]
                    if len(cells) == 1:
                        g2[cells[0][0]][cells[0][1]] = n; changed = True; break
                if changed: break
            if changed: break
    return g2


