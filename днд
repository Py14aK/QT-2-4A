# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
# STAGE 1 \u2014 Generate a random valid solution
# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

def generate_solution(seed=None):
    """Fill a 9\u00d79 grid with a valid Sudoku solution using randomised backtracking."""
    if seed is not None:
        random.seed(seed)
    g = [[0] * 9 for _ in range(9)]

    def possible(g, r, c, n):
        if n in g[r]: return False
        if n in [g[i][c] for i in range(9)]: return False
        br, bc = (r // 3) * 3, (c // 3) * 3
        for i in range(br, br + 3):
            for j in range(bc, bc + 3):
                if g[i][j] == n: return False
        return True

    def fill(g):
        for r in range(9):
            for c in range(9):
                if g[r][c] == 0:
                    nums = list(range(1, 10))
                    random.shuffle(nums)
                    for n in nums:
                        if possible(g, r, c, n):
                            g[r][c] = n
                            if fill(g): return True
                            g[r][c] = 0
                    return False
        return True

    fill(g)
    return g


# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
# STAGE 2 \u2014 Strip clues (minimal unique puzzle)
# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500

def _possible(g, r, c, n):
    if n in g[r]: return False
    if n in [g[i][c] for i in range(9)]: return False
    br, bc = (r // 3) * 3, (c // 3) * 3
    for i in range(br, br + 3):
        for j in range(bc, bc + 3):
            if g[i][j] == n: return False
    return True

def count_solutions(g, limit=2):
    """Count solutions up to `limit` (stops early for speed)."""
    count = [0]
    def solve(g):
        if count[0] >= limit: return
        for r in range(9):
            for c in range(9):
                if g[r][c] == 0:
                    for n in range(1, 10):
                        if _possible(g, r, c, n):
                            g[r][c] = n; solve(g); g[r][c] = 0
                    return
        count[0] += 1
    solve([row[:] for row in g])
    return count[0]

def strip_clues(solution):
    """Remove as many clues as possible while keeping a unique solution."""
    g = [row[:] for row in solution]
    cells = [(r, c) for r in range(9) for c in range(9)]
    random.shuffle(cells)
    for (r, c) in cells:
        val = g[r][c]
        g[r][c] = 0
        if count_solutions(g) != 1:
            g[r][c] = val
    return g


