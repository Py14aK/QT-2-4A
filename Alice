"""
# ============================================================================
# STEP: Measure Quantum States in Given Basis
# ============================================================================
# Original specification:
# Prepare Qubits
# Inputs:
# qs: an array of qubits in the states,
# bases: a Bool array of length ; bases[i] indicates the basis that should 
#        be used to prepare the qubit i:
#        false: use the basis / (computational),
#        true: use the basis / (Hadamard).
# bits: a Bool array of length ; bits[i] indicates the bit to encode in 
#       the i-th qubit: false = 0, true = 1.
# Goal: Prepare the qubits in the described state.
# ============================================================================

from qiskit import QuantumCircuit, QuantumRegister, ClassicalRegister
from qiskit_aer import AerSimulator
from qiskit import transpile

def prepare_qubits(qc, qs, bases, bits):
    """
    Prepare qubits in specified states using given bases.
    
    Args:
        qc: QuantumCircuit to add operations to
        qs: Array of qubit indices to prepare
        bases: Bool array where False = computational, True = Hadamard basis
        bits: Bool array where False = 0 state, True = 1 state
    """
    for qubit_idx, qubit in enumerate(qs):
        # Encode the bit value
        if bits[qubit_idx]:
            # Apply X gate to flip from |0⟩ to |1⟩
            qc.x(qubit)
        
        # Apply basis transformation if needed
        if bases[qubit_idx]:
            # Transform to Hadamard basis (|+⟩ / |-⟩)
            qc.h(qubit)
        # else: stay in computational basis (|0⟩ / |1⟩)

def measure_in_basis(qc, qubit, classical_bit, basis='computational'):
    """
    Measure a qubit in the specified basis.
    
    Args:
        qc: QuantumCircuit to add measurement to
        qubit: Index of qubit to measure
        classical_bit: Index of classical bit to store result
        basis: 'computational' for Z-basis, 'Hadamard' for X-basis
    """
    if basis == 'Hadamard':
        # Transform back to computational basis before measurement
        qc.h(qubit)
    
    # Measure in computational basis (Z-basis)
    qc.measure(qubit, classical_bit)

def measure_quantum_state(num_qubits, bases, bits, measurement_bases):
    """
    Complete workflow to prepare and measure quantum states.
    
    Args:
        num_qubits: Number of qubits in circuit
        bases: Preparation bases for each qubit
        bits: Bit values to encode
        measurement_bases: Bases in which to measure each qubit
    
    Returns:
        counts: Dictionary of measurement outcomes and their frequencies
    """
    # Create quantum and classical registers
    qr = QuantumRegister(num_qubits, 'q')
    cr = ClassicalRegister(num_qubits, 'c')
    qc = QuantumCircuit(qr, cr)
    
    # Prepare the qubits
    prepare_qubits(qc, list(range(num_qubits)), bases, bits)
    
    # Add barrier for clarity
    qc.barrier()
    
    # Measure in specified bases
    for qubit_idx in range(num_qubits):
        measure_in_basis(
            qc, qubit_idx, qubit_idx, 
            measurement_bases[qubit_idx]
        )
    
    # Execute the circuit
    simulator = AerSimulator()
    compiled_qc = transpile(qc, simulator)
    job = simulator.run(compiled_qc, shots=1024)
    result = job.result()
    counts = result.get_counts(compiled_qc)
    
    return counts, qc

# ============================================================================
# Example Usage
# ============================================================================
if __name__ == "__main__":
    # Configuration
    num_qubits = 3
    bases = [False, True, False]  # computational, Hadamard, computational
    bits = [False, True, False]   # |0⟩, |1⟩, |0⟩
    measurement_bases = ['computational', 'Hadamard', 'computational']
    
    # Run measurement
    counts, circuit = measure_quantum_state(
        num_qubits, bases, bits, measurement_bases
    )
    
    # Display results
    print("\n" + "="*60)
    print("QUANTUM STATE MEASUREMENT RESULTS")
    print("="*60)
    print(f"Circuit diagram:\n{circuit.draw(output='text')}")
    print(f"\nMeasurement counts:\n{counts}")
    print("="*60)
"""